rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helper for user registration
    function isValidUser(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'phoneNumber', 'age', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.firstName is string && data.firstName.size() >= 2 && data.firstName.size() <= 50 &&
             data.lastName is string && data.lastName.size() >= 2 && data.lastName.size() <= 50 &&
             data.phoneNumber is string && data.phoneNumber.size() == 11 &&
             data.age is int && data.age >= 1 && data.age <= 120;
    }

    match /users/{userId} {
      allow create: if isValidUser(request.resource.data) && request.resource.data.createdAt == request.time;
      allow read, delete: if true;
    }
  }
}
